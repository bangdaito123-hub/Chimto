local ESP_Cache = {}

RS.RenderStepped:Connect(function()
    local target, dist = nil, math.huge
    for _, v in pairs(game.Players:GetPlayers()) do
        if v ~= LP and v.Character and v.Character:FindFirstChild("HumanoidRootPart") and v.Character:FindFirstChild("Humanoid") and v.Character.Humanoid.Health > 0 then
            local aimPart = v.Character:FindFirstChild(getgenv().AimPart)
            
            if not ESP_Cache[v] then 
                ESP_Cache[v] = Instance.new("Highlight")
            end
            
            local hl = ESP_Cache[v]
            hl.Parent = getgenv().ESP_Highlight and v.Character or nil
            if getgenv().ESP_Highlight then hl.FillColor = Color3.new(1,0,0); hl.OutlineColor = Color3.new(1,1,1) end

            if getgenv().Aimbot and aimPart then
                local pos, onScreen = Camera:WorldToViewportPoint(aimPart.Position)
                if onScreen and IsVisible(aimPart) then
                    local mag = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                    if mag < dist then target = v; dist = mag end
                end
            end
        else
            if ESP_Cache[v] then ESP_Cache[v].Parent = nil end
        end
    end
    if getgenv().Aimbot and target and target.Character:FindFirstChild(getgenv().AimPart) then
        local lookAt = CFrame.new(Camera.CFrame.Position, target.Character[getgenv().AimPart].Position)
        Camera.CFrame = Camera.CFrame:Lerp(lookAt, getgenv().Smoothness)
    end
end)

game.Players.PlayerRemoving:Connect(function(p)
    if ESP_Cache[p] then ESP_Cache[p]:Destroy(); ESP_Cache[p] = nil end
end)

