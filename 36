local function Execute(url)
    task.spawn(function() pcall(function() loadstring(game:HttpGet(url))() end) end)
end

local function AddScript(tab, name, desc, callback)
    tab:CreateButton({
        Name = name,
        Interact = desc,
        Callback = function()
            if type(callback) == "string" then Execute(callback)
            elseif type(callback) == "function" then task.spawn(function() pcall(callback) end) end
        end
    })
end

local function IsVisible(targetPart)
    if not getgenv().WallCheck then return true end
    local hit = workspace:FindPartOnRayWithIgnoreList(Ray.new(Camera.CFrame.Position, (targetPart.Position - Camera.CFrame.Position).Unit * 1000), {LP.Character, Camera})
    return hit and hit:IsDescendantOf(targetPart.Parent)
end

