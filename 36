-- HỆ THỐNG XỬ LÝ LÕI
local function GetClosestPlayer()
    local target, closestDist = nil, 9e9
    for _, v in ipairs(Players:GetPlayers()) do
        if v ~= LP and v.Character and v.Character:FindFirstChild("HumanoidRootPart") and v.Character.Humanoid.Health > 0 then
            local pos, onScreen = Camera:WorldToViewportPoint(v.Character.HumanoidRootPart.Position)
            if onScreen then
                local dist = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)).Magnitude
                if dist < closestDist then closestDist = dist; target = v end
            end
        end
    end
    return target
end

RunService.RenderStepped:Connect(function()
    if getgenv().Aimbot then
        local t = GetClosestPlayer()
        if t and t.Character and t.Character:FindFirstChild(getgenv().AimPart) then 
            Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, t.Character[getgenv().AimPart].Position), getgenv().Smoothness) 
        end
    end
end)

RunService.Heartbeat:Connect(function()
    if not LP.Character then return end
    local hum = LP.Character:FindFirstChild("Humanoid")
    local root = LP.Character:FindFirstChild("HumanoidRootPart")
    
    if hum then 
        if getgenv().WalkSpeed ~= 16 then hum.WalkSpeed = getgenv().WalkSpeed end
        if getgenv().JumpPower ~= 50 then hum.JumpPower = getgenv().JumpPower; hum.UseJumpPower = true end
    end
    
    if getgenv().FlyEnabled and root then
        local bv = root:FindFirstChild("ChimToFlyBV") or Instance.new("BodyVelocity", root)
        local bg = root:FindFirstChild("ChimToFlyBG") or Instance.new("BodyGyro", root)
        bv.Name = "ChimToFlyBV"; bv.maxForce = Vector3.new(9e9, 9e9, 9e9)
        bg.Name = "ChimToFlyBG"; bg.maxTorque = Vector3.new(9e9, 9e9, 9e9); bg.cframe = Camera.CFrame
        
        local dir = Vector3.zero
        local UIS = game:GetService("UserInputService")
        if UIS:IsKeyDown(Enum.KeyCode.W) then dir += Camera.CFrame.LookVector end
        if UIS:IsKeyDown(Enum.KeyCode.S) then dir -= Camera.CFrame.LookVector end
        if UIS:IsKeyDown(Enum.KeyCode.D) then dir += Camera.CFrame.RightVector end
        if UIS:IsKeyDown(Enum.KeyCode.A) then dir -= Camera.CFrame.RightVector end
        bv.velocity = dir * getgenv().FlySpeed
    else
        if root then
            local bv = root:FindFirstChild("ChimToFlyBV"); if bv then bv:Destroy() end
            local bg = root:FindFirstChild("ChimToFlyBG"); if bg then bg:Destroy() end
        end
    end
end)
