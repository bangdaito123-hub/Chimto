local function AddScript(tab, name, url)
    tab:CreateButton({ Name = name, Callback = function()
        task.spawn(function()
            Rayfield:Notify({Title = "Chim To Hub", Content = "Đang chạy: " .. name, Duration = 2})
            local s, e = pcall(function() loadstring(game:HttpGet(url))() end)
            if not s then Rayfield:Notify({Title = "Lỗi", Content = "Script này đã sập hoặc mọt link!", Duration = 3}) end
        end)
    end})
end

